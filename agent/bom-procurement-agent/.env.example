# ── Agent — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your actual values

# ── Mode ─────────────────────────────────────────────────────────────

# Development Mode: in-memory session storage (no database required)
DEV_MODE=true

# Optional: Port for ADK server (defaults to 8000)
PORT=8000

# Optional: Directory containing agent definitions (defaults to current directory)
AGENTS_DIR=.

# ── Database (Production) ──────────────────────────────────────────

# Required in PRODUCTION (DEV_MODE=false): Postgres for ADK session storage
# SESSION_SERVICE_URI=postgresql://user:password@host/database?sslmode=require

# ── LLM ──────────────────────────────────────────────────────────────

# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override default models
# FAST_MODEL=openrouter/moonshotai/kimi-k2.5
# REASONING_MODEL=openrouter/google/gemini-3-pro-preview

# Optional: OpenRouter attribution headers (default: this agent's name).
# OPENROUTER_REFERER=https://github.com/your-org/bom-procurement-agent
# OPENROUTER_TITLE=bom-procurement-agent

# ── Security ─────────────────────────────────────────────────────────

# Recommended: API key for endpoint authentication
# When set, all endpoints except /health require Bearer token or X-API-Key header
# API_KEY=your_secret_api_key_here

# Optional: Enable Swagger/OpenAPI docs in production (disabled by default when API_KEY is set)
# DOCS_ENABLED=false

# ── Resilience ───────────────────────────────────────────────────────

# Optional: Rate limiting for tool calls (token bucket)
# TOOL_RATE_LIMIT=5.0    # requests per second
# TOOL_RATE_BURST=20     # burst capacity

# Optional: Comma-separated list of tools protected by the circuit breaker
# PROTECTED_TOOLS=

# ── Logging ──────────────────────────────────────────────────────────

# Optional: Log format — "json" for production (structured), "text" for dev (colored)
# LOG_FORMAT=text
# LOG_LEVEL=INFO

# Optional: Context filter — number of prior invocations to keep in context window
# CONTEXT_FILTER_KEEP=10

# ── Long-Term Memory ────────────────────────────────────────────────

# Optional: Enable/disable long-term memory (default: true)
# MEMORY_ENABLED=true

# Optional: Max size for core memory file in characters (default: 10000)
# MEMORY_MAX_CORE_SIZE=10000

# Optional: Max size per topic file in characters (default: 5000)
# MEMORY_MAX_TOPIC_SIZE=5000

# ── Writable surfaces (deployment volume) ───────────────────────────
# When deploying with a persistent volume (Railway / Fly / Render), mount
# it (e.g. /data) and point these env vars at it. Locally, leave unset to
# use the in-repo paths. seed_volume_if_empty() runs at agent boot and
# copies the in-repo seeds into the volume on first deploy.
#
# SOUL_FILE=/data/soul/SOUL.md
# AWAKENING_FILE=/data/soul/AWAKENING.md
# SKILLS_DIR=/data/skills
# MEMORY_DIR=/data/memory
#
# For clean local separation between seed (committed) and runtime state,
# point them at a gitignored .runtime/ directory:
# SOUL_FILE=./.runtime/soul/SOUL.md
# SKILLS_DIR=./.runtime/skills
# MEMORY_DIR=./.runtime/memory

# ── Observability / Traces ───────────────────────────────────────────

# Optional: Full agent traces for prompt optimization and evals
# TRACE_ENABLED=true       # set to "false" to disable all tracing
# TRACE_DIR=./traces       # directory for JSONL trace files (always written)
# TRACE_DB=false           # set to "true" to also write traces to PostgreSQL (agent_traces table)

# ── Cost Guard ──────────────────────────────────────────────────────

# Optional: Per-session cost budget in USD (0 = no limit)
# COST_GUARD_BUDGET=0.50

# Optional: Path to custom pricing.json (default: bundled with plugins)
# COST_GUARD_PRICING=./pricing.json

# ── Streaming / Voice Agent ─────────────────────────────────────────

# Optional: Enable bidirectional streaming (voice/video) via Gemini Live API
# Requires GOOGLE_API_KEY. Uses WebSocket at /ws/{user_id}/{session_id}
# STREAMING_ENABLED=false

# Required when STREAMING_ENABLED=true: Google API key for Gemini Live API
# GOOGLE_API_KEY=your_google_api_key_here

# Optional: Gemini model for live streaming (must support Live API)
# LIVE_MODEL=gemini-2.0-flash-live-001
